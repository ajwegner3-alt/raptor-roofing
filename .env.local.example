# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email provider — Gmail SMTP via @nsi/email-sender (copied to src/lib/email/)
EMAIL_PROVIDER=gmail
GMAIL_USER=your.gmail@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
GMAIL_FROM_NAME=Raptor Roofing Website
NOTIFICATION_EMAIL=your.gmail@gmail.com

# reCAPTCHA v3 (invisible) — register at https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# To swap to Resend post-launch, set:
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=...
# (no other code changes required)
